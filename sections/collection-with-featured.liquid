
<script src="{{ 'results-list.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) card.scrollIntoView({ behavior: 'instant' });
      },
      { once: true }
    );
  }
{% endjavascript %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<results-list
  class="section product-grid-container cwf color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div class="collection-wrapper cwf__layout gap-style">

    {%- comment -%} Filters span full width above the split {%- endcomment -%}
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% paginate collection.products by 24 %}

    <div
      id="ResultsList"
      class="cwf__results"
      style="
        --product-grid-gap-mobile: {{ section.settings.columns_gap_vertical | at_most: 12 }}px {{ section.settings.columns_gap_horizontal | at_most: 12 }}px;
        --product-grid-gap-desktop: {{ section.settings.columns_gap_vertical }}px {{ section.settings.columns_gap_horizontal }}px;
        --cwf-gap-v: {{ section.settings.columns_gap_vertical }}px;
        --cwf-gap-v-mobile: {{ section.settings.columns_gap_vertical | at_most: 12 }}px;
      "
    >
      <span ref="viewMorePrevious"></span>

      {%- comment -%} Inner body — spans full collection-wrapper width, own 50/50 grid {%- endcomment -%}
      <div class="cwf__body">

        {%- comment -%} Left: first 4 products in 2-column grid {%- endcomment -%}
        <div class="cwf__products">
          <ul
            class="cwf__grid-featured product-grid product-grid--{{ section.id }}"
            product-grid-view="default"
            ref="grid"
            role="list"
            data-last-page="{{ paginate.pages }}"
            data-product-card-size="{{ section.settings.product_card_size }}"
          >
            {% for product in collection.products limit: 4 %}
              <li
                id="{{ section.id }}-{{ product.id }}"
                class="product-grid__item product-grid__item--{{ forloop.index0 }}"
                data-page="{{ paginate.current_page }}"
                data-product-id="{{ product.id }}"
                ref="cards[]"
              >
                {% # theme-check-disable %}
                {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
                {% # theme-check-enable %}
              </li>
            {% endfor %}
          </ul>
        </div>

        {%- comment -%} Right: featured panel, stretches to match 2-row height {%- endcomment -%}
        <div class="cwf__panel" style="--cwf-image-fit: {{ section.settings.image_fit }};">
          <div class="cwf__panel-inner">
            <a
              class="cwf__panel-link"
              href="{{ section.settings.featured_link | default: '#' }}"
              {% if section.settings.featured_link == blank %}aria-disabled="true"{% endif %}
            >
              {% if section.settings.featured_label != blank %}
                <p class="cwf__panel-label">{{ section.settings.featured_label }}</p>
              {% endif %}

              <div class="cwf__panel-image-wrap">
                {% if section.settings.featured_image != blank %}
                  {% assign cwf_alt = section.settings.featured_image.alt | escape %}
                  {% assign cwf_src = section.settings.featured_image | image_url: width: 1200 %}
                  {% assign cwf_src_400 = section.settings.featured_image | image_url: width: 400 %}
                  {% assign cwf_src_800 = section.settings.featured_image | image_url: width: 800 %}
                  <img
                    src="{{ cwf_src }}"
                    srcset="{{ cwf_src_400 }} 400w, {{ cwf_src_800 }} 800w, {{ cwf_src }} 1200w"
                    sizes="50vw"
                    alt="{{ cwf_alt }}"
                    loading="lazy"
                    class="cwf__panel-image"
                    width="{{ section.settings.featured_image.width }}"
                    height="{{ section.settings.featured_image.height }}"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg cwf__panel-image' }}
                {% endif %}
              </div>

              <div class="cwf__panel-content">
                {% if section.settings.featured_heading != blank %}
                  <h2 class="cwf__panel-heading">{{ section.settings.featured_heading }}</h2>
                {% endif %}
                {% if section.settings.featured_text != blank %}
                  <p class="cwf__panel-text">{{ section.settings.featured_text }}</p>
                {% endif %}
                {% if section.settings.featured_button_label != blank %}
                  <span class="cwf__panel-button button">{{ section.settings.featured_button_label }}</span>
                {% endif %}
              </div>
            </a>
          </div>
        </div>

      </div>{%- comment -%} end cwf__body {%- endcomment -%}

      {%- comment -%} Remaining products — full width, 4 columns {%- endcomment -%}
      {% if collection.products.size > 4 %}
        <ul
          class="cwf__grid-remaining product-grid product-grid--{{ section.id }}"
          product-grid-view="default"
          role="list"
          data-last-page="{{ paginate.pages }}"
          data-product-card-size="{{ section.settings.product_card_size }}"
        >
          {% for product in collection.products offset: 4 %}
            <li
              id="{{ section.id }}-{{ product.id }}"
              class="product-grid__item product-grid__item--{{ forloop.index0 | plus: 4 }}"
              data-page="{{ paginate.current_page }}"
              data-product-id="{{ product.id }}"
              ref="cards[]"
            >
              {% # theme-check-disable %}
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
              {% # theme-check-enable %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      <span ref="viewMoreNext"></span>
    </div>{%- comment -%} end cwf__results {%- endcomment -%}

    {% endpaginate %}

  </div>
</results-list>

{% stylesheet %}
  /* ── Inner two-column body ─────────────────────────────── */
  /* Span all columns of collection-wrapper so it escapes the page-margin grid */
  .cwf__body {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr;

    @media screen and (min-width: 990px) {
      /* Left: remaining space  |  Right: exactly half the viewport */
      grid-template-columns: 1fr 50vw;
      gap: 24px;
      align-items: stretch;
    }
  }

  /* ── Featured grid (2 columns, beside the panel) ────── */
  .cwf__grid-featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--cwf-gap-v-mobile, 12px);
    list-style: none;
    margin: 0;
    padding: 0;

    @media screen and (min-width: 990px) {
      gap: var(--cwf-gap-v, 16px);
    }
  }

  /* ── Remaining products (4 columns, full width below) ── */
  .cwf__grid-remaining {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--cwf-gap-v-mobile, 12px);
    list-style: none;
    margin: 0;
    padding: 0;
    margin-top: var(--cwf-gap-v-mobile, 12px);

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(4, 1fr);
    }

    @media screen and (min-width: 990px) {
      gap: var(--cwf-gap-v, 16px);
      margin-top: var(--cwf-gap-v, 16px);
    }
  }

  /* ── Featured panel ────────────────────────────────────── */
  .cwf__panel {
  }

  .cwf__panel-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cwf__panel-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    height: 100%;
  }

  .cwf__panel-label {
    margin: 0;
    padding: 1rem 1.25rem 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .cwf__panel-image-wrap {
    /* Mobile: fixed aspect ratio so image has visible height */
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 3;

    @media screen and (min-width: 990px) {
      /* Desktop: grow to fill remaining panel height after text content.
         position:relative + absolute image prevents the image's intrinsic
         dimensions from driving the grid row height — the left product
         column dictates height instead. */
      aspect-ratio: unset;
      flex: 1 1 0;
      min-height: 0;
      position: relative;
    }
  }

  .cwf__panel-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--cwf-image-fit, cover);
    object-position: center;
    transition: transform 0.4s ease;

    @media screen and (min-width: 990px) {
      position: absolute;
      inset: 0;
    }
  }

  .cwf__panel-link:hover .cwf__panel-image {
    transform: scale(1.02);
  }

  .cwf__panel-content {
    flex: 0 0 auto;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cwf__panel-heading {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .cwf__panel-text {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.75;
    line-height: 1.5;
  }

  .cwf__panel-button {
    align-self: flex-start;
    margin-top: 0.25rem;
  }

  /* placeholder svg fallback */
  .cwf__panel-image.placeholder-svg {
    background: var(--color-background-2, #f5f5f5);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection + featured",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Featured panel"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover (crop to fill)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "text",
      "id": "featured_label",
      "label": "Label / eyebrow text",
      "placeholder": "e.g. Featured collection"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Heading",
      "default": "Featured Product"
    },
    {
      "type": "textarea",
      "id": "featured_text",
      "label": "Description",
      "default": "A short line about this featured product or collection."
    },
    {
      "type": "text",
      "id": "featured_button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "featured_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Collection grid"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "organic", "label": "Editorial" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "Card size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "extra-large", "label": "Extra large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "Mobile card size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "large", "label": "Large" }
      ],
      "default": "small"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "Grid width",
      "options": [
        { "value": "centered", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "full-width"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "Full width on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "Horizontal gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "Vertical gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": []
}
{% endschema %}
