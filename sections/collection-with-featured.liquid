
<script src="{{ 'results-list.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) card.scrollIntoView({ behavior: 'instant' });
      },
      { once: true }
    );
  }
{% endjavascript %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<results-list
  class="section product-grid-container cwf color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px; --cwf-border-width: {{ section.settings.border_width }}px;{% if section.settings.border_image != blank %} --cwf-border-image: url('{{ section.settings.border_image | image_url: width: 400 }}');{% endif %}"
  section-id="{{ section.id }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div class="collection-wrapper cwf__layout gap-style">

    {%- comment -%} Filters span full width above the split {%- endcomment -%}
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}

    {% paginate collection.products by 24 %}

    <div
      id="ResultsList"
      class="cwf__results"
      style="
        --product-grid-gap-mobile: {{ section.settings.columns_gap_vertical | at_most: 12 }}px {{ section.settings.columns_gap_horizontal | at_most: 12 }}px;
        --product-grid-gap-desktop: {{ section.settings.columns_gap_vertical }}px {{ section.settings.columns_gap_horizontal }}px;
        --cwf-gap-v: {{ section.settings.columns_gap_vertical }}px;
        --cwf-gap-v-mobile: {{ section.settings.columns_gap_vertical | at_most: 12 }}px;
      "
    >
      <span ref="viewMorePrevious"></span>

      {%- comment -%}
        cwf__body is a 4-column grid on desktop.
        Featured grid occupies cols 1-2, panel occupies cols 3-4 (same row).
        Remaining products span all 4 columns below.
        Equal gaps everywhere → all cards are the same width.
      {%- endcomment -%}
      <div class="cwf__body">

        {%- comment -%} Cols 1-2: first 4 products in a 2-column sub-grid {%- endcomment -%}
        <ul
          class="cwf__grid-featured product-grid product-grid--{{ section.id }}"
          product-grid-view="default"
          ref="grid"
          role="list"
          data-last-page="{{ paginate.pages }}"
          data-product-card-size="{{ section.settings.product_card_size }}"
        >
          {% for product in collection.products limit: 4 %}
            <li
              id="{{ section.id }}-{{ product.id }}"
              class="product-grid__item product-grid__item--{{ forloop.index0 }}"
              data-page="{{ paginate.current_page }}"
              data-product-id="{{ product.id }}"
              ref="cards[]"
            >
              {% # theme-check-disable %}
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
              {% # theme-check-enable %}
            </li>
          {% endfor %}
        </ul>

        {%- comment -%} Cols 3-4: featured panel {%- endcomment -%}
        <div class="cwf__panel" style="--cwf-image-fit: {{ section.settings.image_fit }};">
          <div class="cwf__panel-inner">
            <a
              class="cwf__panel-link"
              href="{{ section.settings.featured_link | default: '#' }}"
              {% if section.settings.featured_link == blank %}aria-disabled="true"{% endif %}
            >
              {% if section.settings.featured_label != blank %}
                <p class="cwf__panel-label">{{ section.settings.featured_label }}</p>
              {% endif %}

              <div class="cwf__panel-image-wrap">
                {% if section.settings.featured_image != blank %}
                  {% assign cwf_alt = section.settings.featured_image.alt | escape %}
                  {% assign cwf_src = section.settings.featured_image | image_url: width: 1200 %}
                  {% assign cwf_src_400 = section.settings.featured_image | image_url: width: 400 %}
                  {% assign cwf_src_800 = section.settings.featured_image | image_url: width: 800 %}
                  <img
                    src="{{ cwf_src }}"
                    srcset="{{ cwf_src_400 }} 400w, {{ cwf_src_800 }} 800w, {{ cwf_src }} 1200w"
                    sizes="(min-width: 990px) 50vw, 100vw"
                    alt="{{ cwf_alt }}"
                    loading="lazy"
                    class="cwf__panel-image"
                    width="{{ section.settings.featured_image.width }}"
                    height="{{ section.settings.featured_image.height }}"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg cwf__panel-image' }}
                {% endif %}
              </div>

              <div class="cwf__panel-content">
                {% if section.settings.featured_heading != blank %}
                  <h2 class="cwf__panel-heading">{{ section.settings.featured_heading }}</h2>
                {% endif %}
                {% if section.settings.featured_text != blank %}
                  <p class="cwf__panel-text">{{ section.settings.featured_text }}</p>
                {% endif %}
              </div>
            </a>
          </div>
        </div>

        {%- comment -%} All 4 cols: remaining products {%- endcomment -%}
        {% if collection.products.size > 4 %}
          <ul
            class="cwf__grid-remaining product-grid product-grid--{{ section.id }}"
            product-grid-view="default"
            role="list"
            data-last-page="{{ paginate.pages }}"
            data-product-card-size="{{ section.settings.product_card_size }}"
          >
            {% for product in collection.products offset: 4 %}
              <li
                id="{{ section.id }}-{{ product.id }}"
                class="product-grid__item product-grid__item--{{ forloop.index0 | plus: 4 }}"
                data-page="{{ paginate.current_page }}"
                data-product-id="{{ product.id }}"
                ref="cards[]"
              >
                {% # theme-check-disable %}
                {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
                {% # theme-check-enable %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      </div>{%- comment -%} end cwf__body {%- endcomment -%}

      <span ref="viewMoreNext"></span>
    </div>{%- comment -%} end cwf__results {%- endcomment -%}

    {% endpaginate %}

  </div>
</results-list>

{% stylesheet %}
  /* ── Mobile padding ────────────────────────────────────── */
  @media screen and (max-width: 989px) {
    .cwf__results {
      padding-inline: 1rem;
    }
  }

  /* ── Body: unified 4-column grid on desktop ────────────── */
  /* grid-column: 1/-1 escapes the collection-wrapper margin tracks */
  .cwf__body {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--cwf-gap-v-mobile, 12px);

    @media screen and (min-width: 990px) {
      /* 4 equal columns — featured grid takes cols 1-2, panel takes cols 3-4,
         remaining products span all 4. Equal gap everywhere = equal card widths. */
      grid-template-columns: repeat(4, 1fr);
      gap: var(--cwf-gap-v, 16px);
      align-items: stretch;
    }
  }

  /* ── Featured grid: cols 1-2 on desktop, 2-col sub-grid ── */
  .cwf__grid-featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--cwf-gap-v-mobile, 12px);
    list-style: none;
    margin: 0;
    padding: 0;

    @media screen and (min-width: 990px) {
      grid-column: 1 / 3;
      gap: var(--cwf-gap-v, 16px);
    }
  }

  /* ── Remaining products: all 4 cols on desktop ─────────── */
  .cwf__grid-remaining {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--cwf-gap-v-mobile, 12px);
    list-style: none;
    margin: 0;
    padding: 0;

    @media screen and (min-width: 750px) {
      grid-template-columns: repeat(4, 1fr);
    }

    @media screen and (min-width: 990px) {
      grid-column: 1 / 5;
      gap: var(--cwf-gap-v, 16px);
    }
  }

  /* ── Featured panel: cols 3-4 on desktop ──────────────── */
  @media screen and (min-width: 990px) {
    .cwf__panel {
      grid-column: 3 / 5;
    }
  }

  .cwf__panel-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cwf__panel-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    height: 100%;
  }

  .cwf__panel-label {
    margin: 0;
    padding: 1rem 0 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .cwf__panel-image-wrap {
    /* Mobile: fixed aspect ratio so image has visible height */
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 3;

    @media screen and (min-width: 990px) {
      /* Desktop: grow to fill remaining panel height after text content.
         position:relative + absolute image prevents the image's intrinsic
         dimensions from driving the grid row height — the left product
         column dictates height instead. */
      aspect-ratio: unset;
      flex: 1 1 0;
      min-height: 0;
      position: relative;
    }
  }

  .cwf__panel-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--cwf-image-fit, cover);
    object-position: center;
    transition: transform 0.4s ease;

    @media screen and (min-width: 990px) {
      position: absolute;
      inset: 0;
    }
  }

  .cwf__panel-link:hover .cwf__panel-image {
    transform: scale(1.02);
  }

  .cwf__panel-content {
    flex: 0 0 auto;
    padding: 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cwf__panel-heading {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .cwf__panel-text {
    margin: 0;
    font-size: 0.9rem;
    opacity: 0.75;
    line-height: 1.5;
  }

  .cwf__panel-button {
    align-self: flex-start;
    margin-top: 0.25rem;
  }

  /* ── Camo border on the outer section element ─────────── */
  /* .cwf is on the <results-list> which spans the full section width.
     The two-layer mask donut cuts out the inner content-box area,
     leaving only the padding ring (= the border) visible.
     Standard: mask-composite: exclude
     Safari:   -webkit-mask-composite: destination-out          */
  .cwf {
    position: relative;
  }

  .cwf::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    padding: var(--cwf-border-width, 0px);
    background-image: var(--cwf-border-image, none);
    background-repeat: repeat;
    background-size: auto;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: destination-out;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
  }

  /* placeholder svg fallback */
  .cwf__panel-image.placeholder-svg {
    background: var(--color-background-2, #f5f5f5);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection + featured",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Featured panel"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "image_picker",
      "id": "border_image",
      "label": "Border pattern image"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover (crop to fill)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "text",
      "id": "featured_label",
      "label": "Label / eyebrow text",
      "placeholder": "e.g. Featured collection"
    },
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Heading",
      "default": "Featured Product"
    },
    {
      "type": "textarea",
      "id": "featured_text",
      "label": "Description",
      "default": "A short line about this featured product or collection."
    },
    {
      "type": "text",
      "id": "featured_button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "featured_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Collection grid"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "organic", "label": "Editorial" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "Card size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "extra-large", "label": "Extra large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "Mobile card size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "large", "label": "Large" }
      ],
      "default": "small"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "Grid width",
      "options": [
        { "value": "centered", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "full-width"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "Full width on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "Horizontal gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "Vertical gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": []
}
{% endschema %}
