
{% liquid
  assign slide_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
    endif
  endfor
%}

{% capture image_slides %}
  {% assign slide_index = 0 %}
  {% for block in section.blocks %}
    {% if block.type == 'slide' %}
      {% capture slide_content %}
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 1500
            | image_tag:
              loading: 'lazy',
              alt: block.settings.image.alt | escape,
              class: 'iwts__slide-image',
              widths: '375, 550, 750, 1000, 1250, 1500',
              sizes: '(min-width: 750px) 50vw, 100vw'
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg iwts__slide-image' }}
        {% endif %}
      {% endcapture %}
      {% render 'slideshow-slide', index: slide_index, children: slide_content, slide_id: block.id %}
      {% assign slide_index = slide_index | plus: 1 %}
    {% endif %}
  {% endfor %}
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} disable-section-top-offset iwts spacing-style color-{{ section.settings.color_scheme }} iwts--{{ section.settings.media_width }}{% if section.settings.media_position == 'right' %} iwts--media-right{% endif %}"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="iwts__media">
    <slideshow-component
      style="--slideshow-timeline: {% render 'timeline-scope', count: slide_count, prefix: 'slide' %};"
      initial-slide="0"
      {% if slide_count > 1 %}infinite{% endif %}
    >
      <slideshow-container ref="slideshowContainer">
        {% if slide_count > 1 %}
          {% render 'slideshow-arrows', icon_style: section.settings.arrow_style %}
        {% endif %}
        <slideshow-slides ref="scroller" tabindex="-1">
          {{ image_slides }}
        </slideshow-slides>
      </slideshow-container>
      {% if slide_count > 1 %}
        {%- render 'slideshow-controls',
          style: 'dots',
          item_count: slide_count,
          show_arrows: false,
          controls_on_media: true,
          pagination_position: 'center'
        -%}
      {% endif %}
    </slideshow-component>
  </div>

  <div class="iwts__content">
    <div class="iwts__content-inner">
      {% if section.settings.subheading != blank %}
        <p class="iwts__subheading caption-with-letter-spacing">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="iwts__heading h2">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="iwts__text rte">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="iwts__button button{% if section.settings.button_style == 'secondary' %} button-secondary{% elsif section.settings.button_style == 'link' %} button-link{% endif %}"
          {% if section.settings.button_link == blank %}aria-disabled="true"{% endif %}
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .iwts {
    --iwts-media-columns: 3.5fr;
    --iwts-content-columns: 2.5fr;

    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas: 'media' 'content';

    @media screen and (min-width: 750px) {
      grid-template-columns: var(--iwts-media-columns) var(--iwts-content-columns);
      grid-template-areas: 'media content';
    }
  }

  .iwts--media-right {
    @media screen and (min-width: 750px) {
      grid-template-columns: var(--iwts-content-columns) var(--iwts-media-columns);
      grid-template-areas: 'content media';
    }
  }

  .iwts--medium {
    @media screen and (min-width: 750px) {
      --iwts-media-columns: 1fr;
      --iwts-content-columns: 1fr;
    }
  }

  .iwts--narrow {
    @media screen and (min-width: 750px) {
      --iwts-media-columns: 1fr;
      --iwts-content-columns: 2fr;
    }
  }

  .iwts--narrow.iwts--media-right {
    @media screen and (min-width: 750px) {
      --iwts-media-columns: 1fr;
      --iwts-content-columns: 2fr;
    }
  }

  .iwts__media {
    grid-area: media;
    position: relative;
    overflow: hidden;
  }

  .iwts__media slideshow-component {
    display: block;
    width: 100%;
    height: 100%;
  }

  .iwts__media slideshow-container {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .iwts__media slideshow-slides {
    display: flex;
    overflow: hidden;
    scroll-snap-type: x mandatory;
    width: 100%;
    height: 100%;
    min-height: 300px;

    @media screen and (min-width: 750px) {
      min-height: 400px;
    }
  }

  .iwts__media slideshow-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    overflow: hidden;
  }

  .iwts__slide-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .iwts__media .placeholder-svg {
    width: 100%;
    height: 100%;
    min-height: 300px;
    display: block;
  }

  .iwts__content {
    grid-area: content;
    display: flex;
    align-items: center;
  }

  .iwts__content-inner {
    padding-inline: var(--page-margin);
    padding-block: calc(2 * var(--page-margin));
    display: flex;
    flex-direction: column;
    gap: 1rem;

    @media screen and (min-width: 750px) {
      padding-block: var(--page-margin);
    }
  }

  .section--page-width .iwts__content-inner {
    padding-inline: 0;

    @media screen and (min-width: 750px) {
      padding-inline-start: var(--page-margin);
    }
  }

  .section--page-width .iwts--media-right .iwts__content-inner {
    @media screen and (min-width: 750px) {
      padding-inline-start: 0;
      padding-inline-end: var(--page-margin);
    }
  }

  .iwts__subheading {
    margin: 0;
  }

  .iwts__heading {
    margin: 0;
  }

  .iwts__text {
    margin: 0;
  }

  .iwts__button {
    align-self: flex-start;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image slideshow with text",
  "disabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    {
      "type": "slide",
      "name": "Image slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "media_width",
      "label": "Image width",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ],
      "default": "wide"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "select",
      "id": "arrow_style",
      "label": "Arrow style",
      "options": [
        {
          "value": "arrow",
          "label": "Arrows"
        },
        {
          "value": "chevron",
          "label": "Chevrons"
        },
        {
          "value": "arrows_large",
          "label": "Large arrows"
        },
        {
          "value": "chevron_large",
          "label": "Large chevrons"
        }
      ],
      "default": "arrow"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image slideshow with text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "link",
          "label": "Link"
        }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image slideshow with text",
      "category": "Image",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
